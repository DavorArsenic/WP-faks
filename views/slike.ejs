<!DOCTYPE html>
	<html lang="hr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<!--dodati meta tag bitan za stranicu-->
		<meta name="keywords" content="Music, Songs, Spotify, Database">
		<!--dodati link za css dokumente -->
		<link rel="stylesheet" href="/style.css">
		<link rel="stylesheet" href="/style-slike.css">
		<title>Primjer HTML5 stranice</title> <!--promijeniti odgovarajući tekst na stranici
		ovo je samo predložak-->
	</head>
	<body>
		<header>
		<h1>Dobrodosli na moju web stranicu</h1>
		</header>
		
		<!-- GUMB za prikaz navigacije (CSS only) -->
		<div class="menu-wrapper">
			<button class="menu-btn">☰ Izbornik</button>

			<nav aria-label="Glavna navigacija">
				<ul class="nav-menu">
					<li><a href="/">Popis pjesama</a></li>
					<li><a href="/grafikon">Statistike</a></li>
					<li><a href="/slike">Slike</a></li>
				</ul>
			</nav>
		</div>

		<section class="galerija"> 
			<h1>Dinamička galerija slika</h1>

			<!-- putanja (href) u tagu a je drugačija kad se koristi lightbox od onoga kada želimo da se 
							otvori u novom tabu -->

			<% images.forEach(image => { %>
                
                <figure class="galerija-slika">
                <img src="<%= image.url %>" alt="<%= image.title %>">
                <figcaption><%= image.title %></figcaption>
                </figure>

            <% }) %>

		</section>
		<footer>
		<p>&copy; 2025. Web Programiranje. Sva prava pridrzana.</p>
		</footer>
    </body>
</html>